---
import { getCollection } from 'astro:content';
import '../../../site/style.css';
import '../../../site/style-docs.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const base = import.meta.env.BASE_URL;          // always /codi/docs/
const siteRoot = base.replace(/docs\/$/, '');  // always /codi/

const allDocs = await getCollection('docs');

const GROUP_LABELS: Record<string, string> = {
  guides: 'Guides',
  reference: 'Reference',
  api: 'API Reference',
};
const GROUP_ORDER = ['guides', 'reference', 'api'];

type DocEntry = (typeof allDocs)[number];
const groups: Record<string, DocEntry[]> = {};

for (const doc of allDocs) {
  const topDir = doc.id.split('/')[0];
  if (!GROUP_ORDER.includes(topDir)) continue;

  // For api/ only show top-level files (api/adapters, api/types, etc.)
  // Skip deeply nested entries and the auto-generated README index
  if (topDir === 'api') {
    const parts = doc.id.split('/');
    const lastName = parts[parts.length - 1].toLowerCase();
    if (parts.length > 3) continue;
    if (lastName === 'readme') continue;  // hide TypeDoc root index page
  }

  if (!groups[topDir]) groups[topDir] = [];
  groups[topDir].push(doc);
}

for (const dir of GROUP_ORDER) {
  groups[dir]?.sort((a, b) =>
    (a.data.sidebar?.order ?? 99) - (b.data.sidebar?.order ?? 99)
  );
}

const currentPath = Astro.url.pathname.replace(/\/$/, '');

function docHref(id: string) {
  const slug = id.toLowerCase();
  return `${base}${slug}/`;
}

function isActive(id: string) {
  const href = docHref(id).replace(/\/$/, '');
  return currentPath === href;
}

function docLabel(doc: DocEntry): string {
  if (doc.data.sidebar?.label) return doc.data.sidebar.label;
  if (doc.data.title) return doc.data.title;
  const name = doc.id.split('/').pop() ?? doc.id;
  return name.charAt(0).toUpperCase() + name.slice(1).replace(/-/g, ' ');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Codi</title>
  {description && <meta name="description" content={description} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="noise" aria-hidden="true"></div>

  <nav id="nav">
    <div class="nav-inner">
      <a href={siteRoot} class="logo">codi</a>
      <div class="nav-links" id="nav-links">
        <a href={`${siteRoot}#features`}>Features</a>
        <a href={`${siteRoot}#who`}>Solo &amp; Teams</a>
        <a href={`${siteRoot}#quickstart`}>Quick Start</a>
        <a href={base} class="docs-tab-active">Docs</a>
        <a href="https://github.com/lehidalgo/codi" target="_blank" rel="noopener">GitHub</a>
        <a href={`${siteRoot}#quickstart`} class="btn-primary">Install</a>
      </div>
      <button class="docs-search-trigger" id="docs-search-trigger" aria-label="Search documentation" aria-keyshortcuts="Control+K Meta+K">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <span>Search</span>
        <kbd>⌘K</kbd>
      </button>
      <button class="hamburger" id="hamburger" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <div class="docs-page">
    <aside class="docs-sidebar" id="docs-sidebar">
      <nav aria-label="Documentation navigation">
        <!-- Static catalog link -->
        <div class="docs-nav-group">
          <div class="docs-nav-label">Browse</div>
          <a href={`${base}catalog/`} class={`docs-nav-link${currentPath.endsWith('/catalog') ? ' active' : ''}`}>
            Artifact Catalog
          </a>
        </div>
        {GROUP_ORDER.filter(g => groups[g]?.length).map(group => (
          <div class="docs-nav-group">
            <div class="docs-nav-label">{GROUP_LABELS[group]}</div>
            {groups[group].map(doc => (
              <a href={docHref(doc.id)} class={`docs-nav-link${isActive(doc.id) ? ' active' : ''}`}>
                {docLabel(doc)}
              </a>
            ))}
          </div>
        ))}
      </nav>
    </aside>

    <main class="docs-main">
      <article class="docs-content">
        <slot />
      </article>
    </main>

    <aside class="docs-toc" id="docs-toc" aria-label="On this page">
      <span class="docs-toc-label">On this page</span>
      <ul class="docs-toc-list" id="docs-toc-list"></ul>
    </aside>
  </div>

  <!-- Search modal -->
  <div class="search-modal" id="search-modal" role="dialog" aria-modal="true" aria-label="Search documentation" hidden>
    <div class="search-backdrop" id="search-backdrop"></div>
    <div class="search-box">
      <div class="search-input-row">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="search" id="search-input" placeholder="Search documentation..." autocomplete="off" spellcheck="false" />
        <button class="search-close" id="search-close" aria-label="Close search">
          <kbd>Esc</kbd>
        </button>
      </div>
      <div class="search-results" id="search-results"></div>
      <div class="search-footer">
        <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
        <span><kbd>↵</kbd> open</span>
        <span><kbd>Esc</kbd> close</span>
      </div>
    </div>
  </div>

  <!-- Mobile sidebar toggle -->
  <button class="docs-sidebar-toggle" id="docs-sidebar-toggle" aria-label="Toggle sidebar" aria-expanded="false">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
  <div class="docs-overlay" id="docs-overlay"></div>

  <script>
    // Nav scroll glow
    const nav = document.getElementById('nav');
    if (nav) {
      window.addEventListener('scroll', () => {
        nav.classList.toggle('scrolled', window.scrollY > 24);
      }, { passive: true });
    }

    // Hamburger toggle
    const hamburger = document.getElementById('hamburger');
    const navLinks = document.getElementById('nav-links');
    if (hamburger && navLinks) {
      hamburger.addEventListener('click', () => {
        const open = navLinks.classList.toggle('open');
        hamburger.setAttribute('aria-expanded', String(open));
      });
    }

    // Mobile docs sidebar toggle
    const sidebarToggle = document.getElementById('docs-sidebar-toggle');
    const docsSidebar = document.getElementById('docs-sidebar');
    const docsOverlay = document.getElementById('docs-overlay');
    if (sidebarToggle && docsSidebar && docsOverlay) {
      const openSidebar = () => {
        docsSidebar.classList.add('open');
        docsOverlay.classList.add('open');
        sidebarToggle.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      };
      const closeSidebar = () => {
        docsSidebar.classList.remove('open');
        docsOverlay.classList.remove('open');
        sidebarToggle.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      };
      sidebarToggle.addEventListener('click', () => {
        docsSidebar.classList.contains('open') ? closeSidebar() : openSidebar();
      });
      docsOverlay.addEventListener('click', closeSidebar);
    }

    // Heading anchor links
    document.querySelectorAll<HTMLElement>('.docs-content h2, .docs-content h3, .docs-content h4').forEach(h => {
      if (h.closest('.docs-card')) return;
      if (!h.id) {
        h.id = h.textContent?.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') ?? '';
      }
      const anchor = document.createElement('a');
      anchor.href = '#' + h.id;
      anchor.className = 'heading-anchor';
      anchor.setAttribute('aria-label', 'Link to this section');
      const svgNS = 'http://www.w3.org/2000/svg';
      const svg = document.createElementNS(svgNS, 'svg');
      svg.setAttribute('width', '14'); svg.setAttribute('height', '14');
      svg.setAttribute('viewBox', '0 0 24 24'); svg.setAttribute('fill', 'none');
      svg.setAttribute('stroke', 'currentColor'); svg.setAttribute('stroke-width', '2');
      svg.setAttribute('stroke-linecap', 'round'); svg.setAttribute('stroke-linejoin', 'round');
      const p1 = document.createElementNS(svgNS, 'path');
      p1.setAttribute('d', 'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71');
      const p2 = document.createElementNS(svgNS, 'path');
      p2.setAttribute('d', 'M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71');
      svg.appendChild(p1); svg.appendChild(p2);
      anchor.appendChild(svg);
      h.appendChild(anchor);
    });

    // TOC: build from headings and wire up scroll-spy
    (function() {
      const article = document.querySelector<HTMLElement>('.docs-content');
      const tocList = document.getElementById('docs-toc-list');
      const tocSidebar = document.getElementById('docs-toc');
      if (!article || !tocList || !tocSidebar) return;

      const headings = Array.from(
        article.querySelectorAll<HTMLElement>('h2, h3')
      );

      if (headings.length < 2) {
        tocSidebar.style.visibility = 'hidden';
        return;
      }

      headings.forEach(h => {
        if (!h.id) {
          h.id = h.textContent?.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') ?? '';
        }
        const li = document.createElement('li');
        li.className = `docs-toc-item depth-${h.tagName === 'H3' ? 3 : 2}`;
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.className = 'docs-toc-link';
        a.textContent = h.textContent ?? '';
        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Scroll-spy with IntersectionObserver
      const links = Array.from(tocList.querySelectorAll<HTMLAnchorElement>('.docs-toc-link'));
      let active: HTMLAnchorElement | null = null;

      const setActive = (link: HTMLAnchorElement) => {
        if (active === link) return;
        active?.classList.remove('active');
        link.classList.add('active');
        active = link;
      };

      const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const link = links.find(l => l.getAttribute('href') === `#${entry.target.id}`);
            if (link) setActive(link);
          }
        });
      }, { rootMargin: '-20% 0px -70% 0px' });

      headings.forEach(h => observer.observe(h));
      if (links[0]) setActive(links[0]);
    })();

    // Code copy buttons
    document.querySelectorAll<HTMLElement>('.docs-content pre').forEach(pre => {
      const code = pre.querySelector('code');
      if (!code) return;
      const btn = document.createElement('button');
      btn.className = 'docs-copy-btn';
      btn.title = 'Copy';
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
      pre.style.position = 'relative';
      pre.appendChild(btn);
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText(code.textContent ?? '').then(() => {
          btn.classList.add('copied');
          setTimeout(() => btn.classList.remove('copied'), 1500);
        });
      });
    });
    // Search
    (function() {
      const modal = document.getElementById('search-modal');
      const backdrop = document.getElementById('search-backdrop');
      const input = document.getElementById('search-input') as HTMLInputElement | null;
      const results = document.getElementById('search-results');
      const trigger = document.getElementById('docs-search-trigger');
      const closeBtn = document.getElementById('search-close');
      if (!modal || !input || !results || !trigger) return;

      let pagefind: any = null;
      let selectedIndex = -1;

      const openSearch = async () => {
        modal.hidden = false;
        input.focus();
        if (!pagefind) {
          try {
            pagefind = await import('/codi/docs/_pagefind/pagefind.js');
            await pagefind.init();
          } catch {
            results.textContent = 'Search index not available. Run npm run docs:build first.';
          }
        }
      };

      const closeSearch = () => {
        modal.hidden = true;
        input.value = '';
        results.textContent = '';
        selectedIndex = -1;
      };

      trigger.addEventListener('click', openSearch);
      backdrop?.addEventListener('click', closeSearch);
      closeBtn?.addEventListener('click', closeSearch);

      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          modal.hidden ? openSearch() : closeSearch();
        }
        if (!modal.hidden && e.key === 'Escape') closeSearch();
        if (!modal.hidden && (e.key === 'ArrowDown' || e.key === 'ArrowUp')) {
          e.preventDefault();
          const items = results.querySelectorAll<HTMLAnchorElement>('.search-result-item');
          if (!items.length) return;
          items[selectedIndex]?.classList.remove('selected');
          selectedIndex = e.key === 'ArrowDown'
            ? Math.min(selectedIndex + 1, items.length - 1)
            : Math.max(selectedIndex - 1, 0);
          items[selectedIndex]?.classList.add('selected');
          items[selectedIndex]?.scrollIntoView({ block: 'nearest' });
        }
        if (!modal.hidden && e.key === 'Enter') {
          const selected = results.querySelector<HTMLAnchorElement>('.search-result-item.selected');
          if (selected) { selected.click(); closeSearch(); }
        }
      });

      let debounce: ReturnType<typeof setTimeout>;
      input.addEventListener('input', () => {
        clearTimeout(debounce);
        debounce = setTimeout(async () => {
          const q = input.value.trim();
          results.textContent = '';
          selectedIndex = -1;
          if (!q || !pagefind) return;
          const search = await pagefind.debouncedSearch(q);
          if (!search?.results?.length) {
            const empty = document.createElement('p');
            empty.className = 'search-empty';
            empty.textContent = 'No results for "' + q + '"';
            results.appendChild(empty);
            return;
          }
          const top = search.results.slice(0, 8);
          for (const r of top) {
            const data = await r.data();
            const a = document.createElement('a');
            a.href = data.url;
            a.className = 'search-result-item';
            const title = document.createElement('span');
            title.className = 'search-result-title';
            title.textContent = data.meta?.title ?? data.url;
            const excerpt = document.createElement('span');
            excerpt.className = 'search-result-excerpt';
            excerpt.textContent = data.excerpt?.replace(/<[^>]+>/g, '') ?? '';
            a.appendChild(title);
            a.appendChild(excerpt);
            a.addEventListener('click', closeSearch);
            results.appendChild(a);
          }
        }, 150);
      });
    })();
  </script>
</body>
</html>
