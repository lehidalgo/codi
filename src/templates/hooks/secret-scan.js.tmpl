#!/usr/bin/env node
// Secret scanner
const fs = require('fs');

// Exclude env var template references like ${VAR_NAME} — placeholders, not secrets
const ENV_VAR_REF = /\$\{[A-Z_]+\}/;

const PATTERNS = [
  /(?:api[_-]?key|apikey)\s*[:=]\s*['"][^'"]{8,}/i,
  /(?:secret|password|passwd|pwd)\s*[:=]\s*['"][^'"]{8,}/i,
  /(?:token|bearer)\s*[:=]\s*['"][^'"]{8,}/i,
  /-----BEGIN (?:RSA |EC |DSA )?PRIVATE KEY-----/,
  /ghp_[a-zA-Z0-9]{36}/,
  /sk-[a-zA-Z0-9]{32,}/,
];

const files = process.argv.slice(2);
let found = false;
for (const file of files) {
  try {
    const lines = fs.readFileSync(file, 'utf-8').split('\n');
    for (const line of lines) {
      if (ENV_VAR_REF.test(line)) continue;
      for (const pattern of PATTERNS) {
        if (pattern.test(line)) {
          console.error(`Potential secret found in ${file}`);
          found = true;
          break;
        }
      }
      if (found) break;
    }
  } catch {}
}
if (found) process.exit(1);
