{
  "skill_name": "sheets-sync",
  "skill_type": "single",
  "version": "0.2.0",
  "manifest_required": false,
  "user_invocable": false,
  "events_emitted": [
    "sheet_row_upserted",
    "sheet_row_appended",
    "sheet_row_read",
    "sheet_sync_failed",
    "sheet_sync_queued",
    "sheet_reconciled"
  ],
  "human_approval_required_for": [
    "writing planning columns outside project-workflow.sync",
    "deleting rows from the project Sheet"
  ],
  "column_zones": {
    "planning": [
      "as_a",
      "i_want",
      "so_that",
      "acceptance_criteria",
      "priority",
      "assigned_to",
      "parent_story",
      "elaborated_from",
      "title",
      "outcome",
      "metric",
      "type",
      "behavior_or_threshold",
      "satisfies"
    ],
    "execution": [
      "workflow_type",
      "branch",
      "commit_shas",
      "design_doc_path",
      "pr_url",
      "pr_state",
      "merged_sha",
      "merged_at",
      "started_at",
      "completed_at",
      "status"
    ]
  },
  "event_to_columns": {
    "workflow_started": ["status", "workflow_type", "branch", "started_at", "assigned_to"],
    "phase_transitioned": ["status"],
    "commit_landed": ["commit_shas"],
    "design_doc_authored": ["design_doc_path"],
    "pr_opened": ["pr_url", "pr_state", "status"],
    "pr_merged": ["pr_state", "merged_sha", "merged_at", "status", "completed_at"],
    "workflow_abandoned": ["status", "completed_at"]
  },
  "boundaries": {
    "produces": "Google Sheet writes mapped from manifest events; read primitives for workflow inputs; reconcile from manifest",
    "does_not_produce": "the conceptual model — that is project-workflow's job",
    "does_not_handle": "stakeholder elicitation (use project-workflow), raw material conversion (use ingest-material)"
  }
}
