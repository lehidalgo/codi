{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codi.dev/schemas/gate-result/v1.0.0",
  "title": "Gate Result",
  "description": "Structured verdict produced by a gate check. Returned by both deterministic and agent (subagent) checks.",
  "type": "object",
  "properties": {
    "verdict": { "enum": ["pass", "fail"] },
    "check_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "suggested_action": { "type": "string" },
    "tokens_consumed": { "type": "integer", "minimum": 0 }
  },
  "required": ["verdict", "check_id"],
  "additionalProperties": false
}
