# Auto-detect text files, normalize to LF
* text=auto eol=lf

# Explicit text files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.toml  text eol=lf
*.sh    text eol=lf
*.txt   text eol=lf

# Branch-local files — always keep ours during merges
# doc-stamp is re-generated per branch; conflicts are never meaningful
docs/project/.doc-stamp merge=ours
# uv.lock: develop is the source of truth; keep ours on sync-merges
uv.lock merge=ours

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
