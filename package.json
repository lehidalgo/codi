{
  "name": "codi-cli",
  "version": "0.3.0",
  "description": "Unified configuration platform for AI coding agents",
  "type": "module",
  "bin": {
    "codi": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lehidalgo/codi.git"
  },
  "homepage": "https://github.com/lehidalgo/codi#readme",
  "bugs": {
    "url": "https://github.com/lehidalgo/codi/issues"
  },
  "author": "lehidalgo",
  "license": "MIT",
  "keywords": [
    "ai",
    "coding-agents",
    "configuration",
    "cli",
    "claude",
    "cursor",
    "codex"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "prompts": "^2.4.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
