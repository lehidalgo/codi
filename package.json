{
  "name": "codi-cli",
  "version": "3.0.0",
  "description": "Unified configuration platform for AI coding agents",
  "type": "module",
  "bin": {
    "codi": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "imports": {
    "#src/*": "./src/*",
    "#tests/*": "./tests/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "preinstall": "npx -y only-allow npm",
    "build": "tsup",
    "regen:phase-refs": "tsx scripts/regenerate-phase-refs.mjs",
    "regen:phase-refs:force": "tsx scripts/regenerate-phase-refs.mjs --force",
    "validate:codi": "tsx scripts/validate-codi-artifacts.mjs",
    "test:agent-harness": "CODI_AGENT_TESTS=1 vitest run tests/agent-harness",
    "test": "vitest run",
    "test:python": "uv run pytest src/templates/skills/",
    "test:all": "sh -c 'vitest run; VCODE=$?; uv run pytest src/templates/skills/; PCODE=$?; [ \"$VCODE\" -eq 0 ] && [ \"$PCODE\" -eq 0 ]'",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:pre-commit": "vitest run tests/unit tests/integration",
    "test:pre-push": "vitest run tests/release",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit && node scripts/guard-no-internal-barrels.mjs && node scripts/guard-layering.mjs && node scripts/guard-agent-identity.mjs && node scripts/guard-project-literals.mjs && node scripts/guard-console-usage.mjs",
    "dev": "tsup --watch",
    "prepare": "husky && node scripts/setup-husky-hooks.mjs",
    "preversion": "npm run lint && npm run build && npm run test",
    "postversion": "git push --follow-tags",
    "prepublishOnly": "[ \"$CI\" = \"true\" ] || [ \"$(git rev-parse --abbrev-ref HEAD)\" = \"main\" ] || (echo 'ERROR: publish only allowed from main branch' && exit 1) && npm run lint && npm run test && npm run build",
    "start": "node dist/cli.js",
    "docs:generate": "node dist/cli.js docs --generate",
    "docs:validate": "node dist/cli.js docs --validate",
    "docs:dev": "astro dev",
    "docs:build": "node dist/cli.js docs --catalog && typedoc && astro build && pagefind --site site/docs --output-path site/docs/_pagefind",
    "docs:check": "astro check",
    "docs:preview": "node preview-server.mjs"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lehidalgo/codi.git"
  },
  "homepage": "https://github.com/lehidalgo/codi#readme",
  "bugs": {
    "url": "https://github.com/lehidalgo/codi/issues"
  },
  "author": "lehidalgo",
  "license": "MIT",
  "keywords": [
    "ai",
    "coding-agents",
    "configuration",
    "cli",
    "claude",
    "cursor",
    "codex",
    "copilot",
    "github-copilot"
  ],
  "dependencies": {
    "@clack/core": "1.2.0",
    "@clack/prompts": "^1.1.0",
    "@hono/node-server": "^2.0.2",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "alpinejs": "3.14.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "diff": "^8.0.4",
    "drizzle-orm": "^0.45.2",
    "fast-glob": "^3.3.3",
    "gpt-tokenizer": "^3.4.0",
    "hono": "^4.12.18",
    "htmx.org": "2.0.4",
    "marked": "^18.0.3",
    "picocolors": "^1.1.0",
    "smol-toml": "^1.6.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^8.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "astro": "^6.1.4",
    "codi-cli": "^0.9.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "pagefind": "^1.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "pyright": "^1.1.408",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typedoc-plugin-zod": "^1.4.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "fast-uri": ">=3.1.2"
  }
}
